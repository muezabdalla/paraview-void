# Template file for 'paraview'
pkgname=ParaView
version=v6.1.0
revision=1
build_style=cmake
configure_args="-DCMAKE_INSTALL_PREFIX=/usr/lib/paraview -DPARAVIEW_QT_VERSION=6
 -DPARAVIEW_ENABLE_FFMPEG=ON -DCMAKE_BUILD_TYPE=Release
 -DPARAVIEW_BUILD_DEVELOPER_DOCUMENTATION=OFF -DPARAVIEW_USE_PYTHON=ON
 -DVTK_SMP_IMPLEMENTATION_TYPE=TBB"
hostmakedepends="cmake"
makedepends="qt6-qt5compat-devel python3-devel ffmpeg-devel tbb-devel qt6-tools-devel qt6-svg-devel xmlsec1"
depends=""
short_desc="the world’s leading open source post-processing visualization engine."
maintainer="muez <muezabdalla777@gmail.com>"
license="BSD-3-Clause"
homepage="https://www.paraview.org/"
distfiles="https://www.paraview.org/paraview-downloads/download.php?submit=Download&version=v6.1&type=source&os=Sources&downloadFile=ParaView-v6.1.0.tar.gz"
checksum="bcb9796a6c9355742cf9efed49b7e36f03cbdee24ece00458e6616c1747ea51b"
python_version=3

post_install() {
 vmkdir usr/bin
 for f in paraview paraview-config pvbatch pvdataserver pvrenderserver pvserver smTestDriver-pv6.1 sqlitebin-pv6.1 tokenize vtkParseJava-pv6.1 vtkProbeOpenGLVersion-pv6.1 vtkProcessXML-pv6.1 vtkWrapClientServer-pv6.1 vtkWrapHierarchy-pv6.1 vtkWrapJava-pv6.1 vtkWrapPython-pv6.1 vtkprotoc-pv6.1; do
  ln -s /usr/lib/paraview/bin/${f} ${DESTDIR}/usr/bin/${f}
 done
}
